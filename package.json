{
  "name": "badminton-planner",
  "version": "1.0.0",
  "description": "Badmington Club Planner App Next.js + React + Expo",
  "license": "ISC",
  "author": "Pavlin Panev",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "badminton-web",
    "badminton-mobile",
    "badminton-shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --w badminton-web --if-present\" \"npm run dev --w badminton-mobile --if-present\"",
    "build": "npm run build --workspaces --if-present",
    "db:seed:performance": "npm run db:seed:performance --workspace badminton-web",
    "db:migrate": "npm run db:migrate --workspace badminton-web",
    "test:performance": "node scripts/performance-check.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
